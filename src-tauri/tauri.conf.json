{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WanyaoClient",
  "version": "2.0.0",
  "identifier": "com.wanyao.client",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "node server.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "万遥客户端",
        "url": "index.html",
        "label": "main",
        "width": 1000,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "minimizable": true,
        "maximizable": true,
        "closable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Wanyao",
    "category": "Utility",
    "shortDescription": "万遥客户端",
    "longDescription": "一个现代化的客户端应用程序",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": true
      },
      "wix": {
        "language": ["zh-CN", "en-US"]
      }
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    }
  },
  "plugins": {}
}
